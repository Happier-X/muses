      "css": ".ds-song-row{display:flex;align-items:center;gap:12px;min-height:72px;padding:8px 12px;font-family:system-ui,sans-serif}.ds-song-row-playing{background:rgba(0,111,238,.1)}.ds-song-cover{width:52px;height:52px;border-radius:10px;background:rgba(146,148,156,.16);flex-shrink:0}.ds-song-text{display:flex;flex-direction:column;gap:2px;min-width:0}.ds-song-text strong{font-size:15px;font-weight:600}.ds-song-text span{font-size:13px;color:#92949c}"

      "css": ".ds-mini-player{display:flex;align-items:center;gap:12px;min-height:64px;padding:8px 12px;border-top:1px solid rgba(0,0,0,.08);background:#fff;color:#000;font-family:system-ui,sans-serif}.ds-mini-cover{width:48px;height:48px;border-radius:10px;background:rgba(146,148,156,.16)}.ds-mini-meta{display:flex;flex-direction:column;gap:3px;min-width:0}.ds-mini-meta strong{font-size:15px;font-weight:600;line-height:1.25}.ds-mini-meta span{font-size:13px;color:#92949c}"

{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "happier-ui": ["./packages/happier-ui/src/index.ts"],
      "happier-ui/*": ["./packages/happier-ui/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "packages/happier-ui/src/**/*.ts",
    "packages/happier-ui/src/**/*.vue"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
